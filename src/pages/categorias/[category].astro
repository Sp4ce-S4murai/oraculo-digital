---
// src/pages/categorias/[category].astro
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DossierCard from "../../components/DossierCard.astro";

export async function getStaticPaths() {
    const allPosts = await getCollection("artigos");

    const uniqueCategories = [
        ...new Set(allPosts.map((post) => post.data.category)),
    ];

    return uniqueCategories.map((category) => {
        const filteredPosts = allPosts.filter((post) => post.data.category === category);
        return {
            params: { category },
            props: { posts: filteredPosts },
        };
    });
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`Classificação Departamental: ${category}`}>
    <div class="border-b-4 border-octo-ink mb-8 pb-4">
        <div class="font-mono text-xs font-bold text-octo-stamp uppercase tracking-widest mb-2 border-l-4 border-octo-stamp pl-2">
            Catálogo de Evidências por Departamento
        </div>
        <h1 class="text-octo-ink font-display font-bold text-3xl md:text-5xl uppercase leading-none">
            Diretório Relacional: 
            <span class="inline-block mt-2 font-mono text-base md:text-3xl border-2 border-octo-ink p-2 shadow-[4px_4px_0_0_rgba(28,35,49,1)] bg-octo-paper text-octo-ink">
                {category}
            </span>
        </h1>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
            <DossierCard 
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                evidenceScale={post.data.evidenceScale}
                slug={post.id}
            />
        ))}
    </div>
</BaseLayout>
