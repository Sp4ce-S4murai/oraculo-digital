---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import DossierCard from '../components/DossierCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('artigos', ({ data }) => {
  return data.isDraft !== true;
});

// Ordenar do mais recente para o mais antigo
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = sortedPosts[0];
const otherPosts = sortedPosts.slice(1);
---

<BaseLayout title="O.C.T.O. - Arquivo Central">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        {/* COLUNA ESQUERDA (Featured e Grade de Arquivos) */}
        <div class="lg:col-span-8 flex flex-col gap-8">
            {featuredPost && (
                <article class="border-4 border-octo-ink p-6 bg-octo-paper shadow-[8px_8px_0_0_#1C2331] group relative">
                    <div class="font-mono font-bold uppercase text-octo-ink text-sm mb-4 border-b-2 border-octo-ink pb-2 tracking-widest">
                        FEATURED POST
                    </div>
                    
                    <a href={`/artigos/${featuredPost.id}`} class="block mb-4">
                        <h2 class="font-display font-bold uppercase text-4xl md:text-5xl leading-tight text-octo-ink group-hover:underline decoration-4 underline-offset-4">
                            {featuredPost.data.title}
                        </h2>
                    </a>
                    
                    <div class="font-display text-lg md:text-2xl font-bold uppercase border-b-2 border-octo-ink pb-4 mb-4 text-octo-ink">
                        {featuredPost.data.tags?.join('. ')}. {featuredPost.data.category}.
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                        <div class="font-serif text-base md:text-lg leading-relaxed text-justify text-octo-ink hyphens-auto">
                            {featuredPost.data.description}
                            
                            <a href={`/artigos/${featuredPost.id}`} class="block mt-6 border-2 border-octo-ink bg-octo-ink text-octo-paper font-mono font-bold uppercase p-3 text-center text-sm md:text-base hover:bg-transparent hover:text-octo-ink transition-colors">
                                Ler Relatório Completo &raquo;
                            </a>
                        </div>
                        {/* Se houvesse uma imagem de capa poderíamos exibir, aqui renderizamos uma caixa vazia estilosa se não tiver */}
                        {featuredPost.data.coverImage ? (
                            <div class="border-4 border-octo-ink p-2 bg-white">
                                <img src={featuredPost.data.coverImage} alt="Gráfico de Exemplo" class="w-full grayscale contrast-125 object-cover aspect-square"/>
                            </div>
                        ) : (
                            <div class="border-4 border-octo-ink p-2 bg-octo-paper grid grid-cols-10 grid-rows-10 gap-1 aspect-square opacity-60 relative overflow-hidden">
                                {/* Simulação Visual de Gráfico O.C.T.O. caso o post não tenha capa */}
                                <div class="col-span-12 row-span-12 w-full h-full bg-octo-grid border border-octo-stamp opacity-50 absolute"></div>
                                <div class="absolute inset-0 flex items-center justify-center font-mono text-xs font-bold text-octo-stamp uppercase rotate-45 border-y border-octo-stamp w-[150%] -left-1/4 origin-center">NO VISUAL DATA</div>
                            </div>
                        )}
                    </div>
                </article>
            )}

            {/* Grid Adicional de Postagens Menores */}
            {otherPosts.length > 0 && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-2">
                    {otherPosts.map((post) => (
                        <DossierCard 
                            title={post.data.title}
                            description={post.data.description}
                            pubDate={post.data.pubDate}
                            category={post.data.category}
                            evidenceScale={post.data.evidenceScale}
                            slug={post.id}
                        />
                    ))}
                </div>
            )}
        </div>

        {/* COLUNA DIREITA (Widgets O.C.T.O.) */}
        <aside class="lg:col-span-4 flex flex-col gap-8">
            
            {/* Widget: Diretório */}
            <div class="border-4 border-octo-ink bg-octo-paper shadow-[8px_8px_0_0_#1C2331]">
                <div class="bg-octo-ink text-octo-paper p-4 md:p-6 pb-4">
                    <h3 class="font-display font-bold text-3xl uppercase leading-none mb-1">
                        DIRETÓRIO DO O.C.T.O.
                    </h3>
                    <span class="font-display font-bold text-lg opacity-80 uppercase tracking-widest">
                        (CATEGORY FILTER)
                    </span>
                </div>
                <ul class="flex flex-col font-display font-bold text-lg md:text-xl uppercase text-octo-ink">
                    <li class="border-b-2 border-octo-ink">
                        <a href="/categorias/Departamento de Transmissões" class="block p-4 md:px-6 hover:bg-octo-ink hover:text-octo-paper transition-colors">DEPARTAMENTO DE TRANSMISSÕES</a>
                    </li>
                    <li class="border-b-2 border-octo-ink">
                        <a href="/categorias/Unidade de Coleta de Objetos" class="block p-4 md:px-6 hover:bg-octo-ink hover:text-octo-paper transition-colors">UNIDADE DE COLETA DE OBJETOS</a>
                    </li>
                    <li class="border-b-2 border-octo-ink">
                        <a href="/categorias/Análise de Anomalias" class="block p-4 md:px-6 hover:bg-octo-ink hover:text-octo-paper transition-colors">ARQUIVO DE FENÔMENOS ANÔMALOS</a>
                    </li>
                    <li>
                        <a href="/tags/Varginha" class="block p-4 md:px-6 hover:bg-octo-ink hover:text-octo-paper transition-colors">PESQUISA DE TECNOLOGIA DE FRONTEIRA</a>
                    </li>
                </ul>
            </div>

            {/* Widget: Escala de Evidência */}
            <div class="border-4 border-octo-ink bg-octo-paper shadow-[8px_8px_0_0_#1C2331]">
                <div class="bg-octo-ink text-octo-paper p-4 md:p-6">
                    <h3 class="font-display font-bold text-2xl uppercase tracking-wider leading-none">
                        NÍVEL DE EVIDÊNCIA DO POST
                    </h3>
                </div>
                <div class="p-4 border-b-2 border-octo-ink text-center">
                    <span class="font-display font-bold uppercase text-xl text-octo-ink">NÍVEL DE EVIDÊNCIA DO POST</span>
                </div>
                <div class="grid grid-cols-4 divide-x-2 divide-octo-ink font-mono text-[10px] md:text-xs font-bold uppercase text-center bg-octo-paper text-octo-ink h-32">
                    <div class="p-2 flex flex-col items-center justify-end hover:bg-[#EBE7DF]">
                        <div class="h-2 w-full bg-octo-ink opacity-30 mb-2"></div>
                        <span>LOW LEVEL</span>
                    </div>
                    <div class="p-2 flex flex-col items-center justify-end hover:bg-[#EBE7DF]">
                        <div class="h-6 w-full bg-octo-ink opacity-60 mb-2"></div>
                        <span>MEDIUM LEVELS</span>
                    </div>
                    <div class="p-2 flex flex-col items-center justify-end hover:bg-[#EBE7DF]">
                        <div class="h-10 w-full bg-octo-ink opacity-80 mb-2"></div>
                        <span>HIGH LEVEL</span>
                    </div>
                    <div class="p-2 flex flex-col items-center justify-end hover:bg-[#EBE7DF]">
                        <div class="h-16 w-full bg-octo-ink mb-2"></div>
                        <span>CRITICAL LEVEL</span>
                    </div>
                </div>
            </div>
            
        </aside>
    </div>
</BaseLayout>
